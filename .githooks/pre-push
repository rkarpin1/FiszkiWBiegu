#!/bin/sh
# Uruchom cargo test przed push do master.
# Stdin format: <local_ref> <local_sha> <remote_ref> <remote_sha>

PUSHING_TO_MASTER=false
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/master" ]; then
        PUSHING_TO_MASTER=true
        break
    fi
done

if [ "$PUSHING_TO_MASTER" = false ]; then
    exit 0
fi

echo ">>> Pre-push: cargo test (push do master)"
cd apps/backend && cargo test
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ">>> Testy nie przeszły — push zablokowany."
    exit 1
fi

exit 0
